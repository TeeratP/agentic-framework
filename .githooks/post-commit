#!/usr/bin/env bash
# post-commit: refresh living docs from the just-made commit via headless Claude.
# Safe by design: never fails a commit (always exits 0), guards against a
# self-trigger loop (docs-only commits are skipped), and runs Claude in the
# background so the commit returns immediately.
set -uo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)" || exit 0
LOG="$REPO_ROOT/.git/docs-update.log"

# Guard: no parent commit (first commit) -> nothing to diff against.
git rev-parse -q --verify HEAD~1 >/dev/null 2>&1 || exit 0

# Guard: if the commit touched ONLY the living docs, skip to avoid an
# infinite loop (the hook edits these files, which would re-trigger it).
CHANGED="$(git diff --name-only HEAD~1 HEAD)"
if [ -z "$(printf '%s\n' "$CHANGED" | grep -vE '^(CLAUDE\.md|docs/project\.md)$' || true)" ]; then
  exit 0
fi

# Guard: claude must be on PATH.
if ! command -v claude >/dev/null 2>&1; then
  echo "[docs-hook] claude not on PATH; skipping ($(date +%F))" >>"$LOG" 2>&1 || true
  exit 0
fi

SHA="$(git rev-parse --short HEAD)"
DATE="$(date +%F)"
CTX="$REPO_ROOT/.git/docs-hook-context.txt"

# Write the heavy commit context to a file (NOT inline in the prompt) so we
# avoid shell-expansion / ARG_MAX problems with large diffs. Claude reads it.
{
  echo "Commit: $SHA  Date: $DATE"
  echo
  echo "Message:"
  git log -1 --pretty=%B
  echo
  echo "Stat:"
  git show --stat --oneline HEAD
  echo
  echo "Diff (truncated to 8000 chars):"
  git diff HEAD~1 HEAD | head -c 8000
} > "$CTX"

PROMPT="A commit ($SHA, $DATE) was just made in this repo. Read $CTX for the full commit details (message, stat, diff), then update the living docs:
- docs/project.md: under the '## Status' section keep a 1-3 sentence summary of the current project state; under the '## Recent changes' section PREPEND one bullet exactly '- $SHA $DATE — <one-line summary>' and keep at most 15 bullets (drop the oldest). Both sections are delimited by '<!-- AUTO-MAINTAINED ... -->' HTML comments; edit only inside those markers.
- CLAUDE.md: edit ONLY if this commit changed the framework's architecture, public API, the '>' DSL semantics, node types, or the state shape; otherwise leave CLAUDE.md completely untouched.
- Edit only those two files. Do NOT run git and do NOT make any commits."

# Assemble the command as an array for safe quoting. --allowedTools accepts a
# space-separated list of tool names (each is its own argv item here).
CMD=(claude -p "$PROMPT" --permission-mode acceptEdits --allowedTools Read Edit Write)

# Dry-run: print what would run and exit, without calling claude or backgrounding.
if [ "${DOCS_HOOK_DRYRUN:-0}" = "1" ]; then
  printf '[docs-hook DRYRUN] would run:\n%s\n' "${CMD[*]}"
  exit 0
fi

# Run in the background, non-blocking; the commit returns immediately.
( cd "$REPO_ROOT" && "${CMD[@]}" >>"$LOG" 2>&1 ) &
disown 2>/dev/null || true

exit 0
